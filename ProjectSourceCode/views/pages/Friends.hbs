{{> message}}

<div class="container my-5">
    <div class="text-center mb-5">
    <h1 class="dashboard-title">
  <span style="color: #3CC86A;">My</span><span style="color: #1EAACC;"> Mini</span><span style="color: #B87FD4;">Friends</span>
</h1>
    <div class="title-divider"></div>
  </div>

    <!-- Add Friend Form -->
<div class="row justify-content-center mb-5">
  <div class="col-md-6">
    <div class="friends-card">
      <h5 class="fw-bold mb-3" style="font-family: 'Nunito', sans-serif; color: #2d2d3a;">Add a Friend</h5>
      <form action="/friends/add" method="POST" class="d-flex gap-2">
        <input type="text" name="friend_username" class="friend-input form-control" placeholder="Enter username" required>
        <button type="submit" class="btn btn-dashboard text-white" style="white-space: nowrap;">Add Friend</button>
      </form>
    </div>
  </div>
</div>

    <!-- Friends List -->
    {{#if friends.length}}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="list-group">
                {{#each friends}}
                <div class="list-group-item d-flex justify-content-between align-items-center custom-card-hover">
                    <div>
                        <a href="/profile/{{this.friend_id}}" style="text-decoration: none; color: inherit;">
                            <h6 class="mb-0 fw-bold custom-card-hover" friend_id="{{this.friend_id}}" style="display: inline-block;">
                                <script>
                                  (function() {
                                    try {
                                      const script = document.currentScript;
                                      const container = script.closest('[friend_id]');
                                      const friendID = container.getAttribute('friend_id');
                                      fetch(`/friends/getProfile?username=${friendID}`)
                                      .then(res => res.json())
                                      .then(profile => {
                                        const pfp = document.createElement('img');
                                        pfp.src = profile.profile_picture || '/Images/profile.png';
                                        pfp.alt = 'Profile Picture';
                                        pfp.className = 'profile-avatar mb-3';
                                        pfp.style = 'width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 2px solid #e3e6f0; margin-right: 10px';
                                        container.prepend(pfp);
                                    })
                                    .catch(() => {
                                      const pfp = document.createElement('img');
                                      pfp.src = '/Images/profile.png';
                                      pfp.alt = 'Profile Picture';
                                      pfp.className = 'profile-avatar mb-3';
                                      pfp.style = 'width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 2px solid #e3e6f0; margin-right: 10px';
                                      container.prepend(pfp);
                                    });
                                  } catch(err) {
                                    console.error(err);
                                  }
                                })();
                                </script>
                                {{this.friend_id}}
                            </h6>
                        </a>
                        <br>
                        <small class="text-muted">Friends since {{this.created_at}}</small>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                      <a href="/profile/{{this.friend_id}}" class="btn btn-outline-primary btn-sm">Profile</a>
                      
                      <form action="/friends/remove" method="POST" class="m-0">
                          <input type="hidden" name="friend_username" value="{{this.friend_id}}">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                      </form>
                  </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>
    {{else}}
    <p class="text-center text-muted mt-4">You haven't added any friends yet. Search for a username above!</p>
    {{/if}}
</div>

<style>
    .custom-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .custom-card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
    }

    .friends-card {
    background: #ffffff;
    border-radius: 18px;
    padding: 28px 28px;
    box-shadow: 0 8px 40px rgba(30,170,204,0.10), 0 2px 8px rgba(0,0,0,0.05);
  }

  .friend-input {
    border: 2px solid #e3e6f0 !important;
    border-radius: 10px !important;
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    color: #2d2d3a;
    background: #fafbff;
  }
  .friend-input:focus {
    border-color: #1EAACC !important;
    box-shadow: 0 0 0 3px rgba(30,170,204,0.14) !important;
  }

  .friends-list {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(30,170,204,0.10), 0 2px 8px rgba(0,0,0,0.05);
  }

  .friend-item {
    border: none !important;
    border-bottom: 1px solid #e3e6f0 !important;
    padding: 16px 20px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .friend-item:last-child {
    border-bottom: none !important;
  }
  .friend-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(30,170,204,0.12) !important;
    z-index: 1;
    position: relative;
  }

  .btn-remove {
    background: linear-gradient(135deg, #e05a7a 0%, #c0395a 100%);
    border: none;
    border-radius: 8px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(220,80,100,0.18);
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-remove:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>