{{> message}}

<div class="container my-5">
    <h1 class="mb-4 text-center">My Friends</h1>

    <!-- Add Friend Form -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Add a Friend</h5>
                    <form action="/friends/add" method="POST" class="d-flex gap-2">
                        <input type="text" name="friend_username" class="form-control" placeholder="Enter username" required>
                        <button type="submit" class="btn btn-primary text-white" style="white-space: nowrap;">Add Friend</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Friends List -->
    {{#if friends.length}}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="list-group">
                {{#each friends}}
                <div class="list-group-item d-flex justify-content-between align-items-center custom-card-hover">
                    <div>
                        <h6 class="mb-0 fw-bold">{{this.friend_id}}</h6>
                        <small class="text-muted">Friends since {{this.created_at}}</small>
                    </div>
                    <form action="/friends/remove" method="POST">
                        <input type="hidden" name="friend_username" value="{{this.friend_id}}">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                    </form>
                </div>
                {{/each}}
            </div>
        </div>
    </div>
    {{else}}
    <p class="text-center text-muted mt-4">You haven't added any friends yet. Search for a username above!</p>
    {{/if}}
</div>

<style>
    .custom-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .custom-card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
    }
</style>
