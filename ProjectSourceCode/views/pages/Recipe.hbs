<style>
    body{
        padding-top: 140px;
    }
</style>

{{> message}}
<h1 class="mb-4">Recipes</h1>
<div class="container-fluid py-5 px-5" id="recipesBody" style="height: 800px">
<div class="row">
<div class="col-md-6">
    <h2>Recipe of the Day</h2>
  {{#if randomRecipe}}
  <div class="card shadow-sm mb-5" id="recipeOfTheDay" style="max-height: 500px; max-width: 600px">
    <div class="card-body">

      <!-- Row 1: Image and Title -->
      <div class="row mb-4 align-items-center">
        <div class="col-md-3">
          <img src="{{randomRecipe.meals.[0].strMealThumb}}" 
               class="img-fluid rounded" 
               style="object-fit: cover; max-height: 150px; width: 100%;" 
               alt="{{randomRecipe.meals.[0].strMeal}}">
        </div>
        <div class="col-md-9">
          <h3>{{randomRecipe.meals.[0].strMeal}}</h3>
          <span class="badge bg-secondary">{{randomRecipe.meals.[0].strArea}}</span>
        </div>
      </div>

      <!-- Row 2: Ingredients and Instructions -->
      <div class="row">
        <div class="col-md-4">
          <h5>Ingredients</h5>
          <div class="overflow-auto" style="max-height: 200px;">
            {{> ingredients}}
          </div>
        </div>
        <div class="col-md-8">
          <h5>Instructions</h5>
          <div class="overflow-auto" style="max-height: 200px;">
            {{randomRecipe.meals.[0].strInstructions}}
          </div>
        </div>
      </div>

    </div>
  </div>
  {{else}}
  <div class="alert alert-warning" role="alert">
    No recipe found.
  </div>
  {{/if}}
</div>
<div class="col-md-6" style="display:flex; flex-direction:column; gap:5px; max-width: 600px; min-height:0; overflow-y: auto">  
  <h2>Search by Cuisine: </h2>
  <form action="/Recipe/searchByCuisine">
  <select name="cuisine" style="max-height: 25px" id="searchByCuisine" onchange="this.form.submit()">
    <option>Algerian</option>
<option>American</option>
<option>Argentinian</option>
<option>Australian</option>
<option>British</option>
<option>Canadian</option>
<option>Chinese</option>
<option>Croatian</option>
<option>Dutch</option>
<option>Egyptian</option>
<option>Filipino</option>
<option>French</option>
<option>Greek</option>
<option>Indian</option>
<option>Irish</option>
<option>Italian</option>
<option>Jamaican</option>
<option>Japanese</option>
<option>Kenyan</option>
<option>Malaysian</option>
<option>Mexican</option>
<option>Moroccan</option>
<option>Norwegian</option>
<option>Polish</option>
<option>Portuguese</option>
<option>Russian</option>
<option>Saudi Arabian</option>
<option>Slovakian</option>
<option>Spanish</option>
<option>Syrian</option>
<option>Thai</option>
<option>Tunisian</option>
<option>Turkish</option>
<option>Ukrainian</option>
<option>Uruguayan</option>
<option>Venezuelan</option>
<option>Vietnamese</option>
  </select>
  </form>
  {{#if selectedCuisine}}
  <script>
      document.getElementById('searchByCuisine').value = '{{selectedCuisine}}';
  </script>
  {{/if}}
  {{#if
    filteredRecipes}}
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<div class="overflow-auto" style="height: 433px; overflow-y: scroll; min-height: 0;">
  {{#each filteredRecipes.meals}}
    <div class="card shadow-sm" style="max-width: 600px; height: 500px">
      <div class="card-body">
        <!-- Row 1: Image and Title -->
        <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <img src="{{this.strMealThumb}}" class="img-fluid rounded" style="object-fit: cover; max-height: 150px; width: 100%;" alt="{{this.strMeal}}">
          </div>
          <div class="col-md-9">
            <h3>{{this.strMeal}}</h3>
            <div data-meal-name="{{this.strMeal}}" 
     favorite-recipes-data='{{JSON ../favoriteRecipes}}' data-cuisine="{{../selectedCuisine}}" data-meal-id="{{this.idMeal}}">

<script>
  function searchJSON(data, field, query) {
    if (!data || !Array.isArray(data)) return [];
    if (!query) return data;

    return data.filter(item =>
      item[field]?.toLowerCase().includes(query.toLowerCase())
    );
  }

  (function() {
    try{
    const script = document.currentScript;
    const container = script.closest('[data-meal-name]');
    const mealName = container.getAttribute('data-meal-name');
    const cuisine = container.getAttribute('data-cuisine');
    const mealId = container.getAttribute('data-meal-id');

    // parse JSON
    const favoriteRecipes = JSON.parse(
      container.getAttribute('favorite-recipes-data')
    );

    const recipeMatches = searchJSON(favoriteRecipes, 'recipe_name', mealName);

    const wrapper = document.createElement('div');
    if(recipeMatches.length === 0) {
      wrapper.innerHTML = `
        <h4>
          Favorite
          <input type="checkbox" class="favorite-checkbox"></input>
        </h4>
      `
    } else{
      wrapper.innerHTML = `
        <h4>
          Favorite
          <input type="checkbox" checked class="favorite-checkbox"></input>
        </h4>
      `
    }

    const checkbox = wrapper.querySelector('.favorite-checkbox');

    checkbox.addEventListener('change', function() {
    const originalState = !this.checked; // save state before change
    if (this.checked) {
        axios.post('/Recipe/addFavorite', { recipe_id: mealId, recipe_name: mealName, cuisine: cuisine })
            .catch(() => { checkbox.checked = originalState; }); // revert on error
    } else {
        axios.post('/Recipe/removeFavorite', { recipe_id: mealId })
            .catch(() => { checkbox.checked = originalState; }); // revert on error
    }
});

    container.appendChild(wrapper);
    console.log("RUNNING SCRIPT", mealName, recipeMatches);
    } catch(err){
      console.error(err);
    }
  })();
</script>
</div>
            <!--
            <h4>
              Favorite
            <input type="checkbox" checked=""></input>
            </h4>
            -->
          </div>
        </div>
        <!-- Row 2: Ingredients and Instructions -->
        <div class="row" id="meal-{{this.idMeal}}" data-meal-id="{{this.idMeal}}">
          <script>
            (function() {
              const script = document.currentScript;
              const container = script.closest('[data-meal-id]');
              const mealId = container.getAttribute('data-meal-id');

              axios.get('https://www.themealdb.com/api/json/v1/1/lookup.php', {
                params: { i: mealId }
              })
              .then(response => {
                const recipeDetails = response.data.meals[0];
                const row = document.createElement('div');
                row.style.display = 'flex';
                row.style.gap = '10px';

                const ingredients = document.createElement('div');

                let ingredientsList = '';
                for (let i = 1; i <= 20; i++) {
                  const ingredient = recipeDetails[`strIngredient${i}`];
                  const measure = recipeDetails[`strMeasure${i}`];
                  if (ingredient && ingredient.trim() !== '') {
                    ingredientsList += `${ingredient}: ${measure} <br>`;
                  }
                }

                ingredients.innerHTML = `
                  <div class="col-md-4" style="width: 150px">
                    <h5>Ingredients</h5>
                    <div style="max-height: 200px; overflow-y: auto;">
                      ${ingredientsList}
                    </div>
                  </div>
                `;

                const instructions = document.createElement('div');
                instructions.innerHTML = `
                  <div class="col-md-8" style="width: 280px">
                    <h5>Instructions</h5>
                    <div style="max-height: 200px; overflow-y: auto;">
                      ${recipeDetails.strInstructions}
                    </div>
                  </div>
                `;

                row.appendChild(ingredients);
                row.appendChild(instructions);
                container.appendChild(row);
              })
              .catch(error => console.error(error));
            })();
          </script>
        </div>                         <!-- /row 2 -->
      </div>                           <!-- /card-body -->
    </div>                             <!-- /card -->
  {{/each}}
</div>                                 <!-- /scrollable container -->
  {{/if}}
</div>

<!-- Favorite Rcipes -->

<div class="row mt-4">
  <div class="col-12">
    <h2>My Favorite Recipes</h2>
    {{#if favoriteRecipes.length}}
    <div class="overflow-auto" style="height: 433px; overflow-y: scroll;">
      {{#each favoriteRecipes}}
        <div class="card shadow-sm mb-3" style="max-width: 600px; height: 150px">
          <div class="card-body">
            <h4>{{this.recipe_name}}</h4>
            <span class="badge bg-secondary">{{this.cuisine}}</span>
          </div>
        </div>
      {{/each}}
    </div>
    {{else}}
    <div class="alert alert-info">You have no favorited recipes yet.</div>
    {{/if}}
  </div>
</div>

</div>
</div>