{{> message}}

<style>
    /* Snow Report background image */
    body {
        background: url('/Images/SnowReport.png') no-repeat center center fixed !important;
        background-size: cover !important;
        align-items: flex-start !important;
        justify-content: flex-start !important;
        min-height: auto !important;
    }

    /* Dark overlay so text is readable on top of the image */
    .snow-overlay {
        background: rgba(255, 255, 255, 0.85);
        border-radius: 16px;
        padding: 40px 30px;
        backdrop-filter: blur(6px);
    }

    .snow-page h1 { color: #1a1a2e; font-size: 2rem; }
    .snow-page .subtitle { color: #2c3e50; font-weight: 600; }

    /* Dropdown + button */
    .snow-page .form-select {
        background: #fff;
        border: 1px solid #ccc;
        color: #333;
    }
    .snow-page .form-select option { background: #fff; color: #333; }
    .snow-page .btn-primary {
        background: linear-gradient(135deg, #00b4d8, #0077b6) !important;
        border: none; width: auto; margin-top: 0;
        box-shadow: 0 4px 15px rgba(0,180,216,0.3);
    }
    .snow-page .btn-secondary {
        background: rgba(0,0,0,0.08) !important;
        border: 1px solid #ccc;
        color: #333; width: auto; margin-top: 0;
    }

    /* Forecast table */
    .snow-table {
        background: rgba(255, 255, 255, 0.9);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #ddd;
    }
    .snow-table thead th {
        background: #0077b6 !important;
        color: #ffffff !important;
        border: none;
        font-weight: 700;
        padding: 14px;
    }
    .snow-table tbody td {
        color: #2c3e50;
        border-color: #e8e8e8;
        padding: 12px 14px;
    }
    .snow-table tbody tr:hover { background: rgba(0,180,216,0.08); }

    .resort-name {
        color: #0077b6;
        font-weight: 700;
    }
    .alert-danger { background: #f8d7da; border-color: #dc3545; color: #721c24; }
</style>

<div class="container my-5 snow-page" style="position:relative; z-index:1;">
    <div class="snow-overlay">
        <h1 class="mb-2 text-center">❄️ Snow Report</h1>
        <p class="text-center subtitle mb-4">Select a ski resort for a 7-day forecast</p>

        <!-- Resort Dropdown -->
        <div class="row justify-content-center mb-4">
            <div class="col-md-6">
                <form action="/SnowReport" method="GET" class="input-group">
                    <select name="resort" class="form-select">
                        <option value="">-- Pick a Resort --</option>
                        {{#each resortNames}}
                            <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                    <button type="submit" class="btn btn-primary">Get Forecast</button>
                </form>
            </div>
        </div>

        {{#if error}}
            <div class="alert alert-danger text-center">Could not load forecast. Please try again.</div>
        {{/if}}

        {{#if resort}}
            <h3 class="text-center mb-3 resort-name">🏔️ {{resort}}</h3>
        {{/if}}

        {{#if forecast}}
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="table-responsive">
                    <table class="table text-center snow-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Snowfall (in)</th>
                                <th>High (°F)</th>
                                <th>Low (°F)</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each forecast}}
                            <tr>
                                <td>{{this.date}}</td>
                                <td>
                                    {{#if this.snowfall}}
                                        ❄️ {{this.snowfall}}"
                                    {{else}}
                                        —
                                    {{/if}}
                                </td>
                                <td>{{this.high}}°</td>
                                <td>{{this.low}}°</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        {{/if}}

        <div class="text-center mt-3">
            <a href="/discover" class="btn btn-secondary">← Back to Discover</a>
        </div>
    </div>
</div>