{{> message}}

<style>
    body { overflow-y: auto !important; align-items: flex-start !important; justify-content: flex-start !important; min-height: auto !important; }

    .chat-page { margin-top: 80px; margin-bottom: 100px; }

    .friends-list { list-style: none; padding: 0; margin: 0; }
    .friends-list li a {
        display: block; padding: 12px 16px; text-decoration: none;
        color: #2d2d3a; border-bottom: 1px solid #e3e6f0; font-weight: 600;
    }
    .friends-list li a:hover { background: #f0f2fa; }
    .friends-list li a.active { background: #e8f4fd; border-left: 3px solid #1EAACC; }

    .message-box {
        background: #fafbff; border: 1px solid #e3e6f0; border-radius: 10px;
        padding: 16px; min-height: 300px; max-height: 400px; overflow-y: auto;
    }
    .msg { margin-bottom: 10px; padding: 8px 12px; border-radius: 8px; max-width: 75%; }
    .msg.sent { background: #d1ecf9; margin-left: auto; text-align: right; }
    .msg.received { background: #e9e9e9; margin-right: auto; }
    .msg small { display: block; font-size: 0.75em; color: #888; margin-top: 4px; }

    .send-form { display: flex; gap: 8px; margin-top: 12px; }
    .send-form input[type="text"] { flex: 1; border-radius: 8px !important; }
    .send-form button { width: auto !important; margin-top: 0 !important; padding: 10px 24px !important; border-radius: 8px !important; }
</style>

<div class="container chat-page">
    <h1 class="text-center mb-2">💬 Chat</h1>

    <div id="disclaimer" style="background:#332d1a; color:#e8c44a; text-align:center; padding:10px; cursor:pointer; border:1px solid #d29922; border-radius:8px; margin-bottom:16px;" onclick="this.style.display='none'">
        ⚠️ You can only message people you have friended (click to dismiss)
    </div>

<!--load in all possible friends to message, when selecting a friend you can message them.
If you already have messages with them, it should show the last message and the time it was sent.
-->

    {{#if friends.length}}
    <div class="row">
        <!-- Friends sidebar -->
        <div class="col-md-4">
            <h5>Friends</h5>
            <ul class="friends-list" style="border:1px solid #e3e6f0; border-radius:10px; overflow:hidden;">
                {{#each friends}}
                <li>
                    
                    <a href="/chat?friend={{this.friend_id}}" class="{{#if (eq this.friend_id ../selectedFriend)}}active{{/if}}" friend_id="{{this.friend_id}}">
                        <script>
                            (function() {
                                try {
                                    const script = document.currentScript;
                                    const container = script.closest('[friend_id]');
                                    const friendID = container.getAttribute('friend_id');
                                    fetch(`/friends/getProfile?username=${friendID}`)
                                    .then(res => res.json())
                                    .then(profile => {
                                        const pfp = document.createElement('img');
                                        pfp.src = profile.profile_picture || '/Images/profile.png';
                                        pfp.alt = 'Profile Picture';
                                        pfp.className = 'profile-avatar mb-3';
                                        pfp.style = 'width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 2px solid #e3e6f0; margin-right: 10px';
                                        container.prepend(pfp);
                                    })
                                    .catch(() => {
                                        const pfp = document.createElement('img');
                                        pfp.src = '/Images/profile.png';
                                        pfp.alt = 'Profile Picture';
                                        pfp.className = 'profile-avatar mb-3';
                                        pfp.style = 'width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 2px solid #e3e6f0; margin-right: 10px';
                                        container.prepend(pfp);
                                    });
                                } catch(err) {
                                    console.error(err);
                                }
                            })();
                        </script>
                         {{this.friend_id}}
                    </a>
                </li>
                {{/each}}
            </ul>
        </div>

        <!-- Chat area -->
        <div class="col-md-8">
            {{#if selectedFriend}}
                <h5>Chat with {{selectedFriend}}</h5>
                <div class="message-box">
                    {{#if messages.length}}
                        {{#each messages}}
                        <div class="msg {{#if (eq this.sender ../currentUser)}}sent{{else}}received{{/if}}">
                            <strong>{{this.sender}}</strong>
                            <p style="margin:4px 0 0;">{{this.message}}</p>
                            <small>{{this.sent_at}}</small>
                        </div>
                        {{/each}}
                    {{else}}
                        <p style="color:#888; text-align:center; margin-top:40px;">No messages yet. Say hi!</p>
                    {{/if}}
                </div>

                <form action="/chat/send" method="POST" class="send-form">
                    <input type="hidden" name="receiver" value="{{selectedFriend}}">
                    <input type="text" name="message" placeholder="Type a message..." required autocomplete="off">
                    <button type="submit" class="btn btn-primary">Send</button>
                </form>
            {{else}}
                <p style="color:#888; margin-top:40px; text-align:center;">← Select a friend to start chatting</p>
            {{/if}}
        </div>
    </div>
    {{else}}
        <p class="text-center" style="margin-top:30px;">You have no friends to message.</p>
        <a href="/friends" class="btn btn-primary" style="max-width:300px; margin:16px auto;">Add Friends</a>
    {{/if}}
</div>
