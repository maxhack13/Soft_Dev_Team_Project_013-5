{{> message}}

<div class="container my-4">
    <h1 class="mb-4">Discover Events</h1>
    <div class="row">
        {{#each results}}
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                {{#if images}}
                <img src="{{images.[0].url}}" class="card-img-top" alt="{{name}}">
                {{else}}
                <img src="https://via.placeholder.com/300x200?text=No+Image" class="card-img-top"
                    alt="No image available">
                {{/if}}
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">{{name}}</h5>
                    {{#if dates.start}}
                    <p class="card-text">
                        <strong>Date:</strong> {{dates.start.localDate}}<br>
                        <strong>Time:</strong> {{dates.start.localTime}}
                    </p>
                    {{/if}}
                    <a href="{{url}}" target="_blank" class="btn btn-primary mt-auto">Book Now</a>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
</div>