{{> message}}

<div class="container my-5">
    <h1 class="mb-5 text-center">My Mini Dashboard</h1>
    <div class="row g-4 row-cols-1 row-cols-md-3">
        {{#if apps.length}}
            {{#each apps}}
                <div class="col">
                    <div class="card h-100 shadow-sm custom-card-hover app-card">
                        <img src="{{this.image}}" class="card-img-top" alt="{{this.name}} Image" style="height: 200px; object-fit: cover;">
                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="card-title fw-bold">{{this.name}}</h5>
                            <p class="card-text text-muted">{{this.description}}</p>
                            <a href="{{this.route}}" class="btn btn-primary mt-auto stretched-link text-white">Open {{this.name}}</a>
                        </div>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <div class="col-12 text-center mt-5 w-100">
                <h4 class="text-muted">Your dashboard is currently empty!</h4>
                <p>Please visit the <a href="/search">Search Page</a> to add some apps to your favorites.</p>
            </div>
        {{/if}}
    </div>
</div>

<style>
    .custom-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
    }

    .app-card {
        padding: 0 !important; 
        max-width: 100% !important; 
        overflow: hidden; 
    }
</style>