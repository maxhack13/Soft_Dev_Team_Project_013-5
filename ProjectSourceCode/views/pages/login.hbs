<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<!-- Style Stuff -->
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:  #3CC86A;
      --teal:   #1EAACC;
      --purple: #B87FD4;
      --bg:     #f4f6fb;
      --card:   #ffffff;
      --text:   #2d2d3a;
      --muted:  #7a7a9a;
      --border: #e3e6f0;
      --radius: 14px;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      position: relative;
      z-index: 1;
      background: var(--card);
      border-radius: 22px;
      box-shadow: 0 8px 40px rgba(30,170,204,0.10), 0 2px 8px rgba(0,0,0,0.06);
      padding: 44px 40px 36px;
      width: 100%;
      max-width: 420px;
      animation: fadeUp 0.5s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Logo ── */
    .logo {
      display: flex;
      align-items: center;
      gap: 0;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
      line-height: 1;
    }
    .logo .my   { color: var(--green); }
    .logo .mini { color: var(--teal); }
    .logo .dash { color: var(--purple); }

    .tagline {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 30px;
    }

    /* ── Divider ── */
    .divider {
      height: 3px;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--green), var(--teal), var(--purple));
      margin-bottom: 30px;
      opacity: 0.7;
    }

    /* ── Form ── */
    h1 {
      font-size: 1.35rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 22px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 7px;
    }

    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      font-family: 'Nunito', sans-serif;
      font-size: 0.97rem;
      font-weight: 600;
      color: var(--text);
      background: #fafbff;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    input[type="text"]:focus  { border-color: var(--teal);   box-shadow: 0 0 0 3px rgba(30,170,204,0.14); }
    input[type="password"]:focus { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(184,127,212,0.14); }

    /* ── Button ── */
    .btn-login {
      display: block;
      width: 100%;
      padding: 13px;
      margin-top: 24px;
      border: none;
      border-radius: var(--radius);
      background: linear-gradient(135deg, var(--teal) 0%, var(--purple) 100%);
      color: #fff;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 18px rgba(30,170,204,0.22);
    }
    .btn-login:hover {
      opacity: 0.92;
      transform: translateY(-1px);
      box-shadow: 0 6px 22px rgba(30,170,204,0.30);
    }
    .btn-login:active { transform: scale(0.98); }

    /* ── Footer link ── */
    .register-link {
      text-align: center;
      margin-top: 20px;
      font-size: 0.88rem;
      color: var(--muted);
      font-weight: 600;
    }
    .register-link a {
      color: var(--green);
      text-decoration: none;
      font-weight: 700;
      transition: color 0.2s;
    }
    .register-link a:hover { color: var(--teal); }

    /* ── Alert placeholder (for {{> message}}) ── */
    .alert {
      background: #fff0f5;
      border-left: 4px solid var(--purple);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.88rem;
      color: #7a3a7a;
      margin-bottom: 18px;
      font-weight: 600;
    }
</style>

<div class = "center-page">

<div class="card">
  <div class="logo">
    <span class="my">My</span><span class="mini">Mini</span><span class="dash">Dashboard</span>
  </div>
  <div class="tagline">Your personal mini hub</div>

  <div class="divider"></div>

  {{> message}}

  <form action="/login" method="post">
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" placeholder="Enter your username" required />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="••••••••" required />
    </div>
    <button type="submit" class="btn-login">Login</button>
  </form>

  <p class="register-link">Don't have an account? <a href="/register">Register</a></p>
</div>
</div>
