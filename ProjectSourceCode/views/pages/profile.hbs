{{> message}}

<script>
  async function deleteEvent(location, eventdate, btn) {
    try {
        const response = await fetch('/SnowReport/deleteScheduledEvent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ location, eventdate })
        });
        if (response.ok) {
            // Remove the card from the DOM without reloading
            btn.closest('div.d-flex').remove();
        }
    } catch (err) {
        console.error(err);
    }
}
</script>

<div class="container my-5">

  <!-- Header -->
  <div class="text-center mb-5">
    <h1 class="dashboard-title">
      {{#if isOwnProfile}}
        <span style="color: #3CC86A;">My</span><span style="color: #1EAACC;">Mini</span><span style="color: #B87FD4;">Profile</span>
      {{else}}
        <span style="color: #3CC86A;">{{user}}'s </span><span style="color: #1EAACC;">Mini</span><span style="color: #B87FD4;">Profile</span>
      {{/if}}
    </h1>
    <div class="title-divider"></div>
  </div>

  <div class="row g-4 justify-content-center">

    <!-- Left Column: Profile Picture + Info -->
    <div class="col-md-4">

      <!-- Profile Picture -->
      <div class="profile-card text-center mb-4">
        <img 
        src="{{#if profile.profile_picture}}{{profile.profile_picture}}{{else}}/Images/profile.png{{/if}}" 
        alt="Profile Picture" 
        class="profile-avatar mb-3"
        />
        <h5 class="fw-bold" style="font-family: 'Nunito', sans-serif; color: #2d2d3a;">{{user}}</h5>
        
        {{#if isOwnProfile}}
        <form action="/profile/upload" method="POST" enctype="multipart/form-data" class="mt-3">
          <input type="file" name="profile_picture" id="profile_picture" accept="image/*" class="d-none" onchange="this.form.submit()">
          <label for="profile_picture" class="btn btn-dashboard text-white w-100" style="cursor: pointer;">
            Upload Photo
          </label>
        </form>
        {{/if}}
      </div>

      {{#if isOwnProfile}}
      <div class="profile-card">
        <h5 class="fw-bold mb-3" style="font-family: 'Nunito', sans-serif; color: #2d2d3a;">Account Info</h5>
        <form action="/profile/update" method="POST">
          <div class="mb-3">
            <label class="profile-label">Username</label>
            <input type="text" class="profile-input form-control" value="{{user}}" disabled />
          </div>
          <div class="mb-3">
            <label class="profile-label">Email</label>
            <input type="email" name="email" class="profile-input form-control" placeholder="Enter your email" value="{{#if profile.email}}{{profile.email}}{{/if}}" />
          </div>
          <button type="submit" class="btn btn-dashboard text-white w-100">Save Changes</button>
        </form>
      </div>
      {{/if}}

    </div>

    <!-- Right Column: Favorited Apps -->
    <div class="col-md-8">
      <div class="profile-card">
        <h5 class="fw-bold mb-4" style="font-family: 'Nunito', sans-serif; color: #2d2d3a;">Favorited Apps</h5>

        {{#if favorites.length}}
          <div class="row g-3 row-cols-1 row-cols-md-2">
            {{#each favorites}}
              <div class="col">
                <div class="card h-100 custom-card-hover app-card">
                  <img src="{{this.image}}" class="card-img-top" alt="{{this.app_name}}" style="height: 140px; object-fit: cover;">
                  <div class="card-body text-center d-flex flex-column">
                    <h6 class="fw-bold mb-1">{{this.app_name}}</h6>
                    <a href="{{this.route}}" class="btn btn-dashboard text-white mt-auto btn-sm">Open</a>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state mx-auto text-center">
            <div class="empty-icon mb-3">⭐</div>
            <h6 class="fw-bold mb-2" style="color: #2d2d3a;">No favorites yet!</h6>
            
            {{#if isOwnProfile}}
              <p class="text-muted mb-3">Head to the Search page to add some apps.</p>
              <a href="/search" class="btn btn-dashboard text-white px-4">Go to Search</a>
            {{else}}
              <p class="text-muted mb-3">{{user}} hasn't favorited any apps yet.</p>
            {{/if}}
            
          </div>
        {{/if}}

      </div>
      <!-- Activity Card -->
<div class="profile-card mt-4">
  <h5 class="fw-bold mb-4" style="font-family: 'Nunito', sans-serif; color: #2d2d3a;">Activity</h5>
  <p>Snow Events</p>
  <div id="activity-list">
    <p class="text-muted text-center">Loading...</p>
  </div>
  <br>
  <p>Favorite Recipes</p>
  <div id="food-list">

  </div>
</div>

<script>
  const username = "{{user}}";

  async function loadFavoriteRecipes(username) {
    try {
      // 1. Hit our backend route which handles DB + MealDB fetching
      const response = await fetch(`/Recipe/details/${username}`);
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

      const data = await response.json();
      const container = document.getElementById('food-list');

      // 2. Handle empty state
      if (!data.recipes || data.recipes.length === 0) {
        container.innerHTML = `
          <div class="text-center text-muted py-3">
            <div style="font-size: 2rem;">🍽️</div>
            <p class="mt-2">No favorite recipes yet!</p>
          </div>`;
        return;
      }

      // 3. Render each recipe card
      container.innerHTML = data.recipes.map(recipe => `
        <div class="d-flex align-items-center justify-content-between p-3 mb-2"
             style="background:#fafbff; border-radius:12px; border: 1px solid #e3e6f0;">
          <div>
            <div class="fw-bold" style="color:#2d2d3a;">🍴 ${recipe.name}</div>
            <div class="text-muted" style="font-size:0.85rem;">🌍 ${recipe.cuisine}</div>
          </div>
        </div>
      `).join('');

    } catch (err) {
      console.error('Failed to load favorite recipes:', err);
      document.getElementById('food-list').innerHTML =
        `<p class="text-danger text-center">Could not load recipes.</p>`;
    }
  }

  loadFavoriteRecipes(username);
</script>

<script>
  const isOwnProfile = {{#if isOwnProfile}}true{{else}}false{{/if}};
  const profileUser = "{{user}}";
  async function loadScheduledEvents() {
    try {
      const response = await fetch(`/SnowReport/getScheduledEvents/${profileUser}`);
      const events = await response.json();
      const container = document.getElementById('activity-list');

      if (!events || events.length === 0) {
        container.innerHTML = `
          <div class="text-center text-muted py-3">
            <div style="font-size: 2rem;">⛷️</div>
            <p class="mt-2">No scheduled events yet!</p>
          </div>`;
        return;
      }

      container.innerHTML = events.map(event => `
        <div class="d-flex align-items-center justify-content-between p-3 mb-2" 
             style="background:#fafbff; border-radius:12px; border: 1px solid #e3e6f0;">
          <div>
            <div class="fw-bold" style="color:#2d2d3a;">📍 ${event.location}</div>
            <div class="text-muted" style="font-size:0.85rem;">📅 ${event.eventdate}</div>
          </div>
          ${isOwnProfile ? `
            <button 
                onclick="deleteEvent('${event.location}', '${event.eventdate}', this)"
                style="background:none; border:none; font-size:1.2rem; cursor:pointer;">
                🗑️
            </button>` : ''}
        </div>
      `).join('');

    } catch (err) {
      document.getElementById('activity-list').innerHTML =
        `<p class="text-danger text-center">Could not load events.</p>`;
    }
  }

  async function deleteEvent(location, eventdate, btn) {
    try {
      const response = await fetch('/SnowReport/deleteScheduledEvent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ location, eventdate })
      });
      if (response.ok) {
        btn.closest('div.d-flex').remove();
      }
    } catch (err) {
      console.error(err);
    }
  }

  loadScheduledEvents();
</script>
    </div>

  </div>
</div>

<style>
  .dashboard-title {
    font-family: 'Nunito', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .title-divider {
    height: 3px;
    border-radius: 99px;
    background: linear-gradient(90deg, #3CC86A, #1EAACC, #B87FD4);
    width: 180px;
    margin: 10px auto 0;
    opacity: 0.7;
  }

  .profile-card {
    background: #ffffff;
    border-radius: 18px;
    padding: 28px;
    box-shadow: 0 8px 40px rgba(30,170,204,0.10), 0 2px 8px rgba(0,0,0,0.05);
    margin-bottom: 20px;
  }

  .profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #e3e6f0;
    box-shadow: 0 4px 14px rgba(30,170,204,0.15);
  }

  .profile-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: #7a7a9a;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 7px;
  }

  .profile-input {
    border: 2px solid #e3e6f0 !important;
    border-radius: 10px !important;
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    color: #2d2d3a;
    background: #fafbff;
  }
  .profile-input:focus {
    border-color: #1EAACC !important;
    box-shadow: 0 0 0 3px rgba(30,170,204,0.14) !important;
  }
  .profile-input:disabled {
    background: #f0f2f8;
    color: #7a7a9a;
  }

  .btn-dashboard {
    background: linear-gradient(135deg, #1EAACC 0%, #B87FD4 100%);
    border: none;
    border-radius: 10px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(30,170,204,0.22);
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-dashboard:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .custom-card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: none !important;
    border-radius: 16px !important;
  }
  .custom-card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(30,170,204,0.15) !important;
  }

  .app-card {
    padding: 0 !important;
    overflow: hidden;
  }

  .empty-state {
    max-width: 380px;
    padding: 32px;
  }
  .empty-icon {
    font-size: 2.5rem;
  }
</style>